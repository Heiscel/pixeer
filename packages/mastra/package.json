{
  "name": "@pixeer/mastra",
  "version": "0.0.1",
  "description": "Mastra tool adapter for Pixeer — expose browser DOM tools to Mastra agents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --watch --config tsdown.config.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@mastra/core": ">=0.5.0",
    "pixeer": ">=0.0.1",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@mastra/core": "^0.10.5",
    "@types/node": "^25.0.3",
    "pixeer": "workspace:*",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  },
  "keywords": ["pixeer", "mastra", "browser-agent", "tools", "ai-agent"]
}
