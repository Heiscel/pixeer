{
  "name": "@pixeer/server",
  "version": "0.0.1",
  "description": "Optional server-side tab registry and routing for Pixeer multi-tab coordination",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "NODE_ENV=development tsdown --watch --config tsdown.config.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "pixeer",
    "server",
    "websocket",
    "ai-agent",
    "tab-registry"
  ],
  "engines": {
    "node": ">=18"
  }
}
