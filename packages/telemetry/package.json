{
  "name": "@pixeer/telemetry",
  "version": "0.0.1",
  "description": "Lightweight browser telemetry — Web Vitals, semantic event capture, error monitoring, GDPR-safe session hashing. Under 2KB gzipped.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --watch --config tsdown.config.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^18.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "happy-dom": "^18.0.1",
    "react": "^18.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "keywords": ["telemetry", "web-vitals", "analytics", "error-monitoring", "gdpr", "pixeer"]
}
