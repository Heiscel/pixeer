{
  "name": "@pixeer/livekit-agent",
  "version": "0.0.1",
  "description": "LiveKit voice agent for Pixeer — STT→LLM→TTS voice pipeline with browser DOM automation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "NODE_ENV=development tsdown --watch --config tsdown.config.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@livekit/agents": ">=1.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@livekit/agents": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  },
  "keywords": [
    "pixeer",
    "livekit",
    "voice-agent",
    "stt",
    "tts",
    "browser-agent",
    "dom-automation"
  ],
  "engines": {
    "node": ">=18"
  }
}
