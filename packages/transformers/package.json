{
  "name": "@pixeer/transformers",
  "version": "0.0.1",
  "description": "Local model inference for Pixeer — run browser automation agents entirely on-device via Transformers.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --watch --config tsdown.config.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@huggingface/transformers": ">=3.0.0",
    "pixeer": ">=0.0.1"
  },
  "devDependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@types/node": "^25.0.3",
    "pixeer": "workspace:*",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "keywords": ["pixeer", "transformers", "local-model", "webgpu", "browser-agent", "on-device", "ai-agent"]
}
