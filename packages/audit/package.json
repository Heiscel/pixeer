{
  "name": "@pixeer/audit",
  "version": "0.0.1",
  "description": "Real-time UI quality assurance — WCAG contrast, touch targets, keyboard nav, form labels, rage clicks, layout shift attribution",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --watch --config tsdown.config.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^3.0.0",
    "happy-dom": "^18.0.1",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "accessibility",
    "wcag",
    "audit",
    "color-contrast",
    "a11y",
    "ui-quality",
    "rage-click",
    "layout-shift",
    "pixeer"
  ]
}
